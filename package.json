    "@types/node": "^20.11.24",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "esbuild": "^0.20.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.7.1",
